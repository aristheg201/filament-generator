{
  "name": "filament-workbench",
  "version": "0.1.0",
  "private": true,
  "description": "Version-locked Filament 1.3.22 tooling for Minecraft Fabric 1.21.1",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && node -e \"import('node:fs/promises').then(fs=>fs.rm('.tmp',{recursive:true,force:true}))\"",
    "lint": "eslint . --ext .ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "cli": "pnpm --filter @filament-workbench/cli start"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "adm-zip": "^0.5.16",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}